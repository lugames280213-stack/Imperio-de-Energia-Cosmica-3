        // --- SISTEMA DE FORMATAÇÃO DE NÚMEROS ---
        function formatNumber(num) {
            if (num === 0) return "0";
            const suffixes = ["", "k", "M", "B", "T", "Qa", "Qi", "Sx", "Sp", "Oc", "No", "Dc"];
            const i = Math.floor(Math.log10(Math.max(1, num)) / 3);
            if (i < 1) return num.toFixed(1).replace(/\.0$/, '');
            const suffixIndex = Math.min(i, suffixes.length - 1);
            const formatted = (num / Math.pow(10, suffixIndex * 3)).toFixed(2);
            return `${formatted} ${suffixes[suffixIndex]}J`;
        }

