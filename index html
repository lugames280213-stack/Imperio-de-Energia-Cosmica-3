        // --- LOOP PRINCIPAL DO JOGO ---
        let lastTick = Date.now();

        function gameLoop() {
            const now = Date.now();
            const delta = (now - lastTick) / 1000;
            lastTick = now;

            gameState.playtime += delta;

            // Produção Passiva
            const eps = calculateEps();
            let earned = eps * delta;

            // Produção de Auto-Clicks (Drones)
            if(gameState.autoClicksPerSec > 0) {
                const autoClickDmg = (gameState.clickPower * gameState.prestigeMultiplier) * gameState.autoClicksPerSec;
                earned += autoClickDmg * delta;
            }

            if (earned > 0) {
                gameState.energy += earned;
                gameState.lifetimeEnergy += earned;
            }

            updateMainDisplays();
            checkAchievements();
            updateStatsPanel();

            requestAnimationFrame(gameLoop);
        }

        // --- INICIALIZAÇÃO ---
        window.onload = function() {
            renderProducers();
            renderUpgrades();
            renderAchievements();
            updateMainDisplays();
            updateStatsPanel();
            requestAnimationFrame(gameLoop);
            showToast("Missão Estelar Iniciada! Evolução Rápida Ativada 🚀", "info");
        };

    </script>
</body>
</html>

