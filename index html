    <script>
        // --- MOTOR DE ÁUDIO WEB AUDIO API ---
        class AudioManager {
            constructor() {
                this.ctx = null;
                this.enabled = true;
            }

            init() {
                if (!this.ctx) {
                    this.ctx = new (window.AudioContext || window.webkitAudioContext)();
                }
            }

            playBeep(frequency, type = 'sine', duration = 0.1, volume = 0.1) {
                if (!this.enabled) return;
                this.init();
                if (this.ctx.state === 'suspended') this.ctx.resume();
                try {
                    const osc = this.ctx.createOscillator();
                    const gain = this.ctx.createGain();
                    osc.type = type;
                    osc.frequency.setValueAtTime(frequency, this.ctx.currentTime);
                    gain.gain.setValueAtTime(volume, this.ctx.currentTime);
                    gain.gain.exponentialRampToValueAtTime(0.0001, this.ctx.currentTime + duration);
                    osc.connect(gain);
                    gain.connect(this.ctx.destination);
                    osc.start();
                    osc.stop(this.ctx.currentTime + duration);
                } catch (e) {}
            }

            playClickSound() {
                this.playBeep(600, 'sine', 0.08, 0.05);
                setTimeout(() => this.playBeep(1200, 'sine', 0.04, 0.03), 20);
            }

            playCritSound() {
                this.playBeep(800, 'square', 0.1, 0.1);
                setTimeout(() => this.playBeep(1600, 'square', 0.08, 0.1), 40);
            }

            playPurchaseSound() {
                this.playBeep(330, 'triangle', 0.15, 0.1);
                setTimeout(() => this.playBeep(440, 'triangle', 0.15, 0.1), 80);
                setTimeout(() => this.playBeep(660, 'triangle', 0.25, 0.1), 160);
            }

            playPrestigeSound() {
                if (!this.enabled) return;
                this.init();
                const now = this.ctx.currentTime;
                const osc = this.ctx.createOscillator();
                const gain = this.ctx.createGain();
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(100, now);
                osc.frequency.exponentialRampToValueAtTime(1500, now + 1.2);
                gain.gain.setValueAtTime(0.15, now);
                gain.gain.exponentialRampToValueAtTime(0.0001, now + 1.2);
                osc.connect(gain);
                gain.connect(this.ctx.destination);
                osc.start();
                osc.stop(now + 1.2);
            }
        }

        const audio = new AudioManager();

        // Alternador de Som
