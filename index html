        // --- INTERAÇÃO: COMPRAR E CLICAR ---
        window.buyProducer = function(id) {
            const prod = gameState.producers.find(p => p.id === id);
            if (!prod) return;

            let finalQtyToBuy = 0, finalCost = 0;
            if (gameState.buyQuantity === 'max') {
                const maxData = getBuyMaxAmountAndCost(prod);
                finalQtyToBuy = maxData.amount; finalCost = maxData.cost;
            } else {
                finalQtyToBuy = gameState.buyQuantity;
                for (let i = 0; i < finalQtyToBuy; i++) finalCost += getProducerCost(prod, i);
            }

            if (gameState.energy >= finalCost && finalQtyToBuy > 0) {
                gameState.energy -= finalCost;
                prod.qty += finalQtyToBuy;
                audio.playPurchaseSound();
                renderProducers(); updateMainDisplays(); updateStatsPanel();
            }
        };

        window.buyUpgrade = function(id) {
            const up = gameState.upgrades.find(u => u.id === id);
            if (!up || up.purchased) return;
            if (gameState.energy >= up.cost) {
                gameState.energy -= up.cost;
                up.purchased = true;
                up.effect();
                audio.playPurchaseSound();
                showToast(`Inovação ativada: ${up.name}`);
                renderUpgrades(); renderProducers(); updateMainDisplays(); updateStatsPanel();
            }
        };

