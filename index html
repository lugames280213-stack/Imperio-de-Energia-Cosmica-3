        // --- CÁLCULOS E LÓGICA DE VALORES ---
        function getProducerCost(prod, offset = 0) {
            return Math.floor(prod.baseCost * Math.pow(prod.costMultiplier, prod.qty + offset));
        }

        function getBuyMaxAmountAndCost(prod) {
            let tempQty = 0, totalCost = 0;
            while (true) {
                const nextCost = getProducerCost(prod, tempQty);
                if (gameState.energy >= totalCost + nextCost) { totalCost += nextCost; tempQty++; } 
                else break;
            }
            return { amount: tempQty, cost: totalCost };
        }

        function calculateEps() {
            let totalEps = 0;
            gameState.producers.forEach(p => totalEps += p.qty * p.baseEps);
            return totalEps * gameState.prestigeMultiplier;
        }

        // --- SISTEMA DINÂMICO DE REQUISITO DE ASCENSÃO (1.50x a cada nível) ---
        function getPrestigeRequirement() {
            // Requisito base de 50k, aumenta 1.50x exponencialmente com o nível atual (prestigeCount)
            return Math.floor(50000 * Math.pow(1.50, gameState.prestigeCount));
        }

        // Calcula quantos pontos de prestígio serão conquistados
        function getPrestigePointsCalculated() {
            const currentReq = getPrestigeRequirement();
            if (gameState.lifetimeEnergy < currentReq) return 0;
            
            // Recompensa pontos escalados com base no excesso de energia acumulada acima da meta
            return Math.max(1, Math.floor(Math.sqrt(gameState.lifetimeEnergy / (currentReq / 5))));
        }

