            const bgClass = type === 'achievement' ? 'bg-gradient-to-r from-yellow-600 to-amber-500 border-yellow-400' : 'bg-gray-900 border-gray-700';
            toast.className = `p-4 rounded-xl border shadow-xl flex items-center gap-3 transform translate-y-2 opacity-0 transition-all duration-300 pointer-events-auto ${bgClass}`;
            const icon = type === 'achievement' ? '🏆' : '⚡';
