                <div><h4 class="text-xs font-bold uppercase tracking-widest text-gray-400">Notificação</h4><p class="text-sm text-white font-medium">${text}</p></div>
            `;
            container.appendChild(toast);
            setTimeout(() => toast.classList.remove('translate-y-2', 'opacity-0'), 10);
