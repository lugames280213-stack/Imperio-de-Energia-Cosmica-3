                { id: 'singularity', name: 'Extractor de Singularidade', description: 'Colhe micro buracos negros.', baseCost: 100000, costMultiplier: 1.07, qty: 0, baseEps: 250000, icon: '🕳️' },
                { id: 'white_hole', name: 'Motor de Buraco Branco', description: 'Inverte a gravidade para jorrar energia.', baseCost: 5000000, costMultiplier: 1.07, qty: 0, baseEps: 15000000, icon: '🌌' },
                { id: 'multiverse', name: 'Coletor Multiversal', description: 'Drena energia de outras realidades.', baseCost: 250000000, costMultiplier: 1.07, qty: 0, baseEps: 1000000000, icon: '🔮' }
